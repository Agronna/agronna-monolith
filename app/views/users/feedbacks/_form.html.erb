<%= form_with model: @feedback, url: (@feedback.persisted? ? user_feedback_path(@user, @feedback) : user_feedbacks_path(@user)), local: true, html: { class: "needs-validation" } do |f| %>
  <% if @feedback.errors.any? %>
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
      <strong>Atenção!</strong> <%= pluralize(@feedback.errors.count, "erro encontrado", "erros encontrados") %>:
      <ul class="mb-0 mt-2">
        <% @feedback.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
    </div>
  <% end %>

  <div class="row g-4">
    <div class="col-lg-8">
      <div class="card shadow-sm mb-4">
        <div class="card-header bg-white">
          <h6 class="mb-0">
            <%= icon_svg(:receipt, width: 18, height: 18, class: "me-2") %>
            <%= t("users.employee.feedback_form_section_title") %>
          </h6>
        </div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-md-6">
              <%= f.label :feedback_on, class: "form-label" %>
              <%= f.date_field :feedback_on, class: "form-control", required: true %>
            </div>
            <div class="col-md-6">
              <%= f.label :kind, class: "form-label" %>
              <%= f.select :kind, UserFeedback.kinds.keys.map { |k| [ t("users.employee.feedback_kinds.#{k}"), k ] }, {}, class: "form-select" %>
            </div>
            <div class="col-12">
              <%= f.label :given_by_id, class: "form-label" %>
              <%= f.collection_select :given_by_id, @feedback_givers, :id, :name, { include_blank: t("users.employee.feedback_giver_blank") }, class: "form-select" %>
              <div class="form-text"><%= t("users.employee.feedback_giver_help") %></div>
            </div>
            <div class="col-12">
              <%= f.label :content, class: "form-label" %>
              <%= f.text_area :content, class: "form-control", rows: 6, required: true, placeholder: t("users.employee.feedback_content_placeholder") %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="card shadow-sm mb-4">
        <div class="card-body">
          <p class="small text-muted mb-0"><%= t("users.employee.sidebar_feedback_help") %></p>
        </div>
      </div>
      <div class="d-grid gap-2">
        <%= f.submit(
              @feedback.persisted? ? t("helpers.submit.user_feedback.update") : t("helpers.submit.user_feedback.create"),
              class: "btn btn-primary btn-lg"
            ) %>
        <%= link_to t("users.employee.cancel"), user_path(@user), class: "btn btn-outline-secondary" %>
      </div>
    </div>
  </div>
<% end %>
