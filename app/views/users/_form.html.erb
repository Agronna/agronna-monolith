<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6">

      <div class="card shadow-sm">
        <div class="card-body">

          <h3 class="card-title mb-4 text-center">
            <%= @user.new_record? ? "Novo Usuário" : "Editar Usuário" %>
          </h3>

          <% if @user.errors.any? %>
            <div class="alert alert-danger">
              <strong><%= pluralize(@user.errors.count, "error") %> prevented saving:</strong>
              <ul class="mb-0">
                <% @user.errors.full_messages.each do |msg| %>
                  <li><%= msg %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <%= form_with model: @user, local: true do |f| %>

            <div class="mb-3">
              <%= f.label :name, "Nome", class: "form-label" %>
              <%= f.text_field :name, class: "form-control", placeholder: "Digite o nome", required: true %>
            </div>

            <div class="mb-3">
              <%= f.label :email, "E-mail", class: "form-label" %>
              <%= f.email_field :email, class: "form-control", placeholder: "email@exemplo.com", required: true %>
            </div>

            <div class="mb-3">
              <%= f.label :secretary_id, "Secretaria", class: "form-label" %>
              <%= f.collection_select :secretary_id,
                    @secretaries || [],
                    :id,
                    :name,
                    { include_blank: "Selecione a secretaria" },
                    class: "form-select",
                    required: true %>
            </div>

            <div class="mb-3">
              <%= f.label :password, "Senha", class: "form-label" %>
              <%= f.password_field :password, class: "form-control", placeholder: "Digite a senha" %>
            </div>

            <div class="mb-3">
              <%= f.label :password_confirmation, "Confirmar Senha", class: "form-label" %>
              <%= f.password_field :password_confirmation, class: "form-control", placeholder: "Confirme a senha" %>
            </div>

            <% if current_user.admin? %>
              <div class="mb-3">
                <%= f.label :role, "Role", class: "form-label" %>
                <%= f.select :role,
                  User.roles.slice("sub_admin", "user").keys.map { |r| [r.humanize, r] },
                  {},
                  class: "form-select" %>
              </div>
            <% end %>

            <div class="d-grid">
              <%= f.submit (@user.new_record? ? "Criar Usuário" : "Salvar Alterações"), class: "btn btn-primary" %>
            </div>

          <% end %>

          <div class="text-center mt-3">
            <%= link_to "Voltar", users_path, class: "btn btn-outline-secondary btn-sm" %>
          </div>

        </div>
      </div>

    </div>
  </div>
</div>