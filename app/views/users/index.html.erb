<div class="container mt-4">

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Usuários</h2>

    <% if can? :create, User %>
      <%= link_to "Novo Usuário", new_user_path, class: "btn btn-primary" %>
    <% end %>
  </div>

  <%= search_form_for @q, url: users_path, method: :get, html: { class: "mb-4", data: { turbo_frame: "users_list" } } do |f| %>
    <div class="card shadow-sm mb-3">
      <div class="card-body">
        <h6 class="card-title mb-3">Filtrar</h6>
        <div class="row g-2 g-md-3">
          <div class="col-12 col-md-6 col-lg-3">
            <%= f.label :name_cont, "Nome", class: "form-label small text-muted" %>
            <%= f.search_field :name_cont, class: "form-control form-control-sm", placeholder: "Contém..." %>
          </div>
          <div class="col-12 col-md-6 col-lg-3">
            <%= f.label :email_cont, "E-mail", class: "form-label small text-muted" %>
            <%= f.search_field :email_cont, class: "form-control form-control-sm", placeholder: "Contém..." %>
          </div>
          <div class="col-12 col-md-6 col-lg-2">
            <%= f.label :role_eq, "Perfil", class: "form-label small text-muted" %>
            <%= f.select :role_eq,
                  options_for_select([ [ "Todos", "" ], [ "Admin", 2 ], [ "Sub-admin", 1 ], [ "Usuário", 0 ] ], params.dig(:q, :role_eq)),
                  {},
                  class: "form-select form-select-sm" %>
          </div>
          <div class="col-12 col-md-6 col-lg-2">
            <%= f.label :secretary_id_eq, "Secretaria", class: "form-label small text-muted" %>
            <%= f.select :secretary_id_eq,
                  options_for_select([ [ "Todas", "" ] ] + Secretary.all.map { |s| [ s.name, s.id ] }, params.dig(:q, :secretary_id_eq)&.to_s),
                  {},
                  class: "form-select form-select-sm" %>
          </div>
          <div class="col-12 col-lg-2 d-flex align-items-end gap-1">
            <%= f.submit "Filtrar", class: "btn btn-primary btn-sm" %>
            <%= link_to "Limpar", users_path, class: "btn btn-outline-secondary btn-sm", data: { turbo_frame: "users_list" } %>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <%= turbo_frame_tag "users_list" do %>
    <div class="card shadow-sm">
      <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-2">
          <p class="text-muted small mb-0">
            <% if @pagy.present? %>
              <%== @pagy.info_tag(item_name: "usuário") %>
            <% else %>
              <%= @users.size %> usuário(s)
            <% end %>
          </p>
        </div>

        <div class="table-responsive">
          <table class="table table-striped table-hover align-middle">

            <thead class="table-light">
              <tr>
                <th>Nome</th>
                <th>E-mail</th>
                <th>Cargo</th>
                <th>Secretaria</th>
                <th>Perfil</th>
                <th class="text-end">Ações</th>
              </tr>
            </thead>

            <tbody>
              <% @users.each do |user| %>
                <tr>
                  <td>
                    <strong><%= user.name %></strong>
                  </td>

                  <td>
                    <%= user.email %>
                  </td>

                  <td>
                    <small><%= user.job_title.presence || "—" %></small>
                  </td>

                  <td>
                    <%= user.secretary&.name || "—" %>
                  </td>

                  <td>
                    <% case user.role %>
                    <% when "admin" %>
                      <span class="badge bg-danger">Admin</span>
                    <% when "sub_admin" %>
                      <span class="badge bg-warning text-dark">Sub-admin</span>
                    <% else %>
                      <span class="badge bg-secondary">User</span>
                    <% end %>
                  </td>

                  <td class="text-end">
                    <div class="btn-group btn-group-sm">
                      <%= link_to t("users.employee.view_profile"), user_path(user), class: "btn btn-outline-secondary", data: { turbo_frame: "_top" } %>
                      <% if can? :update, user %>
                        <%= link_to "Editar", edit_user_path(user), class: "btn btn-outline-primary", data: { turbo_frame: "_top" } %>
                      <% end %>
                    </div>
                  </td>

                </tr>
              <% end %>
            </tbody>

          </table>
        </div>

        <div class="d-flex justify-content-center mt-3">
          <% if @pagy.present? && @pagy.pages > 1 %>
            <nav aria-label="Navegação de páginas" class="pagy-bootstrap-nav">
              <%== @pagy.series_nav("bootstrap") %>
            </nav>
          <% end %>
        </div>

      </div>
    </div>
  <% end %>

</div>