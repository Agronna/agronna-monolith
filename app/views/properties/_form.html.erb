<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">

      <div class="card shadow-sm">
        <div class="card-body">

          <h3 class="card-title mb-4 text-center">
            <%= @property.new_record? ? "Nova Propriedade" : "Editar Propriedade" %>
          </h3>

          <% if @property.errors.any? %>
            <div class="alert alert-danger">
              <strong><%= pluralize(@property.errors.count, "erro") %> impediram de salvar:</strong>
              <ul class="mb-0">
                <% @property.errors.full_messages.each do |msg| %>
                  <li><%= msg %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <%= form_with model: @property, local: true do |f| %>

            <h6 class="text-muted border-bottom pb-2 mb-3">Dados da propriedade</h6>

            <div class="row g-3">
              <div class="col-md-6">
                <%= f.label :name, "Nome", class: "form-label" %>
                <%= f.text_field :name, class: "form-control", placeholder: "Nome da propriedade", required: true %>
              </div>
              <div class="col-md-6">
                <%= f.label :producer_id, "Produtor", class: "form-label" %>
                <%= f.collection_select :producer_id, @producers, :id, :name,
                  { prompt: "Selecione o produtor" },
                  class: "form-select", required: true %>
              </div>
              <div class="col-md-4">
                <%= f.label :incra, "INCRA", class: "form-label" %>
                <%= f.text_field :incra, class: "form-control", placeholder: "Código INCRA" %>
              </div>
              <div class="col-md-4">
                <%= f.label :registration, "Matrícula", class: "form-label" %>
                <%= f.text_field :registration, class: "form-control", placeholder: "Nº da matrícula" %>
              </div>
              <div class="col-md-4">
                <%= f.label :status, "Status", class: "form-label" %>
                <%= f.select :status,
                  Property.statuses.keys.map { |s| [s == "active" ? "Ativo" : "Inativo", s] },
                  {},
                  class: "form-select", required: true %>
              </div>
              <div class="col-md-6">
                <%= f.label :localization, "Localização", class: "form-label" %>
                <%= f.text_field :localization, class: "form-control", placeholder: "Ex: Zona Rural, Km 15" %>
              </div>
              <div class="col-12">
                <%= f.label :activity, "Atividade", class: "form-label" %>
                <%= f.text_area :activity, class: "form-control", placeholder: "Descreva a atividade da propriedade", rows: 3, required: true %>
              </div>
            </div>

            <h6 class="text-muted border-bottom pb-2 mb-3 mt-4">Endereço</h6>

            <%= f.fields_for :address do |addr| %>
              <div class="row g-3">
                <div class="col-12">
                  <%= addr.label :street, "Logradouro", class: "form-label" %>
                  <%= addr.text_field :street, class: "form-control", placeholder: "Rua, estrada, etc." %>
                </div>
                <div class="col-md-4">
                  <%= addr.label :number, "Número", class: "form-label" %>
                  <%= addr.text_field :number, class: "form-control", placeholder: "Nº" %>
                </div>
                <div class="col-md-4">
                  <%= addr.label :complement, "Complemento", class: "form-label" %>
                  <%= addr.text_field :complement, class: "form-control", placeholder: "Lote, quadra, etc." %>
                </div>
                <div class="col-md-4">
                  <%= addr.label :neighborhood, "Bairro/Região", class: "form-label" %>
                  <%= addr.text_field :neighborhood, class: "form-control", placeholder: "Bairro ou região" %>
                </div>
                <div class="col-md-5">
                  <%= addr.label :city, "Cidade", class: "form-label" %>
                  <%= addr.text_field :city, class: "form-control", placeholder: "Cidade" %>
                </div>
                <div class="col-md-2">
                  <%= addr.label :state, "UF", class: "form-label" %>
                  <%= addr.text_field :state, class: "form-control", placeholder: "UF", maxlength: 2 %>
                </div>
                <div class="col-md-3">
                  <%= addr.label :zip_code, "CEP", class: "form-label" %>
                  <%= addr.text_field :zip_code, class: "form-control", placeholder: "00000-000" %>
                </div>
                <div class="col-md-2">
                  <%= addr.label :country, "País", class: "form-label" %>
                  <%= addr.text_field :country, class: "form-control", placeholder: "BR" %>
                </div>
              </div>
            <% end %>

            <div class="d-grid mt-4">
              <%= f.submit (@property.new_record? ? "Criar Propriedade" : "Salvar Alterações"), class: "btn btn-primary" %>
            </div>

          <% end %>

        </div>
      </div>

    </div>
  </div>
</div>
