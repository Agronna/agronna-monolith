<div class="container mt-4">

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Propriedades</h2>

    <% if can? :create, Property %>
      <%= link_to "Nova Propriedade", new_property_path, class: "btn btn-primary" %>
    <% end %>
  </div>

  <%= search_form_for @q, url: properties_path, method: :get, html: { class: "mb-4", data: { turbo_frame: "properties_list" } } do |f| %>
    <div class="card shadow-sm mb-3">
      <div class="card-body">
        <h6 class="card-title mb-3">Filtrar</h6>
        <div class="row g-2 g-md-3 align-items-end">
          <div class="col-12 col-sm-6 col-lg-3">
            <%= f.label :name_cont, "Nome", class: "form-label small text-muted" %>
            <%= f.search_field :name_cont, class: "form-control form-control-sm", placeholder: "Contém..." %>
          </div>
          <div class="col-12 col-sm-6 col-lg-2">
            <%= f.label :incra_cont, "INCRA", class: "form-label small text-muted" %>
            <%= f.search_field :incra_cont, class: "form-control form-control-sm", placeholder: "Contém..." %>
          </div>
          <div class="col-12 col-sm-6 col-lg-2">
            <%= f.label :registration_cont, "Matrícula", class: "form-label small text-muted" %>
            <%= f.search_field :registration_cont, class: "form-control form-control-sm", placeholder: "Contém..." %>
          </div>
          <div class="col-12 col-sm-6 col-lg-3">
            <%= f.label :localization_cont, "Localização", class: "form-label small text-muted" %>
            <%= f.search_field :localization_cont, class: "form-control form-control-sm", placeholder: "Contém..." %>
          </div>
          <div class="col-12 col-lg-2 d-flex align-items-end gap-1">
            <%= f.submit "Filtrar", class: "btn btn-primary btn-sm" %>
            <%= link_to "Limpar", properties_path, class: "btn btn-outline-secondary btn-sm", data: { turbo_frame: "properties_list" } %>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <%= turbo_frame_tag "properties_list" do %>
    <div class="card shadow-sm">
      <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-2">
          <p class="text-muted small mb-0">
            <% if @pagy.present? %>
              <%== @pagy.info_tag(item_name: "propriedade") %>
            <% else %>
              <%= @properties.size %> propriedade(s)
            <% end %>
          </p>
        </div>

        <div class="table-responsive">
          <table class="table table-striped table-hover align-middle">

            <thead class="table-light">
              <tr>
                <th>Nome</th>
                <th>INCRA</th>
                <th>Matrícula</th>
                <th>Atividade</th>
                <th>Localização</th>
                <th>Produtor</th>
                <th>Status</th>
                <th class="text-end">Ações</th>
              </tr>
            </thead>

            <tbody>
              <% @properties.each do |property| %>
                <tr>
                  <td><strong><%= property.name %></strong></td>
                  <td><%= property.incra.presence || "—" %></td>
                  <td><%= property.registration.presence || "—" %></td>
                  <td><%= truncate(property.activity, length: 30) %></td>
                  <td><%= property.localization.presence || "—" %></td>
                  <td><%= property.producer&.name || "—" %></td>
                  <td>
                    <span class="badge <%= property.status_active? ? 'bg-success' : 'bg-secondary' %>">
                      <%= property.status_active? ? "Ativo" : "Inativo" %>
                    </span>
                  </td>
                  <td class="text-end">
                    <% if can? :update, property %>
                      <%= link_to "Editar", edit_property_path(property), class: "btn btn-sm btn-outline-primary", data: { turbo_frame: "_top" } %>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>

          </table>
        </div>

        <div class="d-flex justify-content-center mt-3">
          <% if @pagy.present? && @pagy.pages > 1 %>
            <nav aria-label="Navegação de páginas" class="pagy-bootstrap-nav">
              <%== @pagy.series_nav("bootstrap") %>
            </nav>
          <% end %>
        </div>

      </div>
    </div>
  <% end %>

</div>
