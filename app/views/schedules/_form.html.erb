<%= form_with model: @schedule, local: true, url: @schedule.persisted? ? schedule_path(@schedule) : schedules_path, method: @schedule.persisted? ? :patch : :post, html: { class: "needs-validation" } do |f| %>
  <%= f.hidden_field :return_to, value: params[:return_to] %>

  <% if @schedule.errors.any? %>
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
      <strong>Atenção!</strong> <%= pluralize(@schedule.errors.count, "erro encontrado", "erros encontrados") %>:
      <ul class="mb-0 mt-2">
        <% @schedule.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
    </div>
  <% end %>

  <div class="row g-4">
    <div class="col-lg-8">
      <div class="card shadow-sm mb-4">
        <div class="card-header bg-white">
          <h6 class="mb-0">
            <%= icon_svg(:calendar, width: 18, height: 18, class: "me-2") %>
            Data e Horário
          </h6>
        </div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-md-6">
              <%= f.label :service_order_id, t("activerecord.attributes.schedule.service_order"), class: "form-label" %>
              <%= f.collection_select :service_order_id, @service_orders, :id, :code, { prompt: "Selecione a Ordem de Serviço (com pagamento aprovado)..." }, { class: "form-select", required: true } %>
              <small class="text-muted">Apenas OS com comprovante aprovado podem ser agendadas.</small>
            </div>
            <div class="col-md-6">
              <%= f.label :secretary_id, t("activerecord.attributes.schedule.secretary"), class: "form-label" %>
              <%= f.collection_select :secretary_id, @secretaries, :id, :name, { prompt: "Selecione..." }, { class: "form-select", required: true } %>
            </div>
            <div class="col-md-6">
              <%= f.label :scheduled_at, t("activerecord.attributes.schedule.scheduled_at"), class: "form-label" %>
              <%= f.datetime_local_field :scheduled_at, class: "form-control", required: true %>
            </div>
            <div class="col-md-6">
              <%= f.label :scheduled_end_at, t("activerecord.attributes.schedule.scheduled_end_at"), class: "form-label" %>
              <%= f.datetime_local_field :scheduled_end_at, class: "form-control" %>
            </div>
            <div class="col-md-6">
              <%= f.label :status, t("activerecord.attributes.schedule.status"), class: "form-label" %>
              <%= f.select :status, Schedule.statuses.keys.map { |s| [t("schedules.statuses.#{s}"), s] }, {}, class: "form-select" %>
            </div>
          </div>
        </div>
      </div>

      <div class="card shadow-sm mb-4">
        <div class="card-header bg-white">
          <h6 class="mb-0">
            <%= icon_svg(:tractor, width: 18, height: 18, class: "me-2") %>
            Maquinário (disponibilidade)
          </h6>
        </div>
        <div class="card-body">
          <p class="text-muted small mb-3">Selecione os equipamentos que serão utilizados neste agendamento.</p>
          <% if @machines.any? %>
            <div class="row g-2">
              <% @machines.each do |machine| %>
                <div class="col-md-6 col-lg-4">
                  <div class="form-check">
                    <%= check_box_tag "schedule[machine_ids][]", machine.id, @schedule.machine_ids.include?(machine.id), id: "machine_#{machine.id}", class: "form-check-input" %>
                    <label class="form-check-label" for="machine_<%= machine.id %>">
                      <%= machine.name %> <small class="text-muted">(<%= machine.plate %>)</small>
                    </label>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-muted mb-0">Nenhum maquinário cadastrado.</p>
          <% end %>
        </div>
      </div>

      <div class="card shadow-sm mb-4">
        <div class="card-header bg-white">
          <h6 class="mb-0">
            <%= icon_svg(:users, width: 18, height: 18, class: "me-2") %>
            Equipe (disponibilidade)
          </h6>
        </div>
        <div class="card-body">
          <p class="text-muted small mb-3">Selecione os membros da equipe alocados para este agendamento.</p>
          <% if @users.any? %>
            <div class="row g-2">
              <% @users.each do |user| %>
                <div class="col-md-6 col-lg-4">
                  <div class="form-check">
                    <%= check_box_tag "schedule[user_ids][]", user.id, @schedule.assigned_user_ids.include?(user.id), id: "user_#{user.id}", class: "form-check-input" %>
                    <label class="form-check-label" for="user_<%= user.id %>"><%= user.name %></label>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-muted mb-0">Nenhum usuário cadastrado.</p>
          <% end %>
        </div>
      </div>

      <div class="card shadow-sm">
        <div class="card-body">
          <%= f.label :observations, t("activerecord.attributes.schedule.observations"), class: "form-label" %>
          <%= f.text_area :observations, class: "form-control", rows: 3, placeholder: "Observações do agendamento..." %>
        </div>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="card shadow-sm mb-4">
        <div class="card-body">
          <p class="small text-muted mb-0">
            O agendamento só é permitido após o pagamento e aprovação do comprovante da Ordem de Serviço. Aqui você define data/hora da prestação e aloca maquinário e equipe.
          </p>
        </div>
      </div>
      <div class="d-grid gap-2">
        <%= f.submit @schedule.persisted? ? "Atualizar Agendamento" : "Criar Agendamento", class: "btn btn-primary btn-lg" %>
        <%= link_to "Cancelar", @schedule.service_order.present? ? service_order_path(@schedule.service_order) : schedules_path, class: "btn btn-outline-secondary" %>
      </div>
    </div>
  </div>
<% end %>
