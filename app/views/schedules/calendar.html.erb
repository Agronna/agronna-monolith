<div class="container-fluid py-4">
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4">
    <div>
      <h1 class="h3 mb-1">Calendário de Agendamentos</h1>
      <p class="text-muted mb-0">Visualize agendamentos, disponibilidade de maquinário e equipe</p>
    </div>
    <div class="d-flex gap-2 mt-3 mt-md-0 flex-wrap">
      <%= link_to schedules_path, class: "btn btn-outline-secondary" do %>
        Lista
      <% end %>
      <% if can?(:create, Schedule) %>
        <%= link_to new_schedule_path, class: "btn btn-primary" do %>
          <%= icon_svg(:calendar, width: 18, height: 18, class: "me-1") %>
          Novo Agendamento
        <% end %>
      <% end %>
    </div>
  </div>

  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-3">
        <div class="d-flex align-items-center gap-2">
          <%= link_to calendar_schedules_path(start_date: @start_date - 1.month), class: "btn btn-outline-secondary btn-sm" do %>
            ← <%= l(@start_date - 1.month, format: "%B %Y") %>
          <% end %>
          <h2 class="h5 mb-0"><%= l(@start_date, format: "%B %Y") %></h2>
          <%= link_to calendar_schedules_path(start_date: @start_date + 1.month), class: "btn btn-outline-secondary btn-sm" do %>
            <%= l(@start_date + 1.month, format: "%B %Y") %> →
          <% end %>
        </div>
        <div class="d-flex flex-wrap gap-2 align-items-center">
          <span class="small text-muted">Filtros:</span>
          <%= form_with url: calendar_schedules_path, method: :get, local: true, class: "d-flex flex-wrap gap-2 align-items-center" do |f| %>
            <%= f.hidden_field :start_date, value: @start_date %>
            <%= f.select :machine_id, options_from_collection_for_select(@machines, :id, :name, @filter_machine_id), { include_blank: "Todos os maquinários" }, class: "form-select form-select-sm", style: "max-width: 200px;" %>
            <%= f.select :user_id, options_from_collection_for_select(@users, :id, :name, @filter_user_id), { include_blank: "Toda a equipe" }, class: "form-select form-select-sm", style: "max-width: 200px;" %>
            <%= f.submit "Filtrar", class: "btn btn-primary btn-sm" %>
            <%= link_to "Limpar", calendar_schedules_path(start_date: @start_date), class: "btn btn-outline-secondary btn-sm" %>
          <% end %>
        </div>
      </div>

      <div class="schedule-calendar">
        <div class="schedule-calendar__weekdays">
          <% %w[Domingo Segunda Terça Quarta Quinta Sexta Sábado].each do |day| %>
            <div class="schedule-calendar__weekday"><%= day %></div>
          <% end %>
        </div>
        <div class="schedule-calendar__grid">
          <% # Empty cells for days before the first day of the month %>
          <% first_day = @start_date.beginning_of_month %>
          <% start_wday = first_day.wday %>
          <% start_wday.times do %>
            <div class="schedule-calendar__day schedule-calendar__day--other-month"></div>
          <% end %>

          <% # Days of the month %>
          <% (@start_date.beginning_of_month..@start_date.end_of_month).each do |date| %>
            <div class="schedule-calendar__day <%= 'schedule-calendar__day--today' if date == Date.current %>">
              <div class="schedule-calendar__day-number"><%= date.day %></div>
              <div class="schedule-calendar__day-events">
                <% (@schedules_by_date[date] || []).each do |schedule| %>
                  <%= link_to schedule_path(schedule), class: "schedule-calendar__event schedule-calendar__event--#{schedule.status}", title: schedule.service_order.title, data: { turbo_frame: "_top" } do %>
                    <span class="schedule-calendar__event-time"><%= schedule.calendar_starts_at.strftime("%H:%M") %></span>
                    <span class="schedule-calendar__event-title text-truncate"><%= schedule.service_order.code %></span>
                    <% if schedule.machines.any? %>
                      <small class="schedule-calendar__event-meta d-block text-truncate"><%= icon_svg(:tractor, width: 10, height: 10) %> <%= schedule.machines.first.name %></small>
                    <% end %>
                  <% end %>
                <% end %>
              </div>
            </div>
          <% end %>

          <% # Fill remaining cells to complete the grid (next month) %>
          <% last_day = @start_date.end_of_month %>
          <% remaining = 42 - start_wday - last_day.day %>
          <% remaining.times do %>
            <div class="schedule-calendar__day schedule-calendar__day--other-month"></div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="card shadow-sm">
    <div class="card-header bg-white">
      <h6 class="mb-0">Legenda</h6>
    </div>
    <div class="card-body">
      <div class="d-flex flex-wrap gap-3">
        <span class="badge bg-info">Agendado</span>
        <span class="badge bg-primary">Confirmado</span>
        <span class="badge bg-warning text-dark">Em andamento</span>
        <span class="badge bg-success">Concluído</span>
      </div>
      <p class="small text-muted mt-2 mb-0">
        Use os filtros para ver apenas agendamentos que utilizam um maquinário ou que incluem um membro da equipe. Assim você visualiza a disponibilidade.
      </p>
    </div>
  </div>
</div>
