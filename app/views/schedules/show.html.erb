<div class="container-fluid py-4">
  <div class="mb-4">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb mb-2">
        <li class="breadcrumb-item"><%= link_to "Agendamentos", schedules_path %></li>
        <li class="breadcrumb-item active" aria-current="page">
          <% if @schedule.scheduled_at.present? %>
            <%= l(@schedule.scheduled_at, format: :short) %>
          <% else %>
            <%= @schedule.service_order.code %>
          <% end %>
        </li>
      </ol>
    </nav>
  </div>

  <% if @schedule.locked_for_editing? && (current_user.admin? || current_user.account_owner? || current_user.sub_admin?) %>
    <div class="alert alert-info d-flex align-items-start gap-2 mb-4" role="alert">
      <%= icon_svg(:clipboard, width: 20, height: 20, class: "flex-shrink-0 mt-1") %>
      <div class="small mb-0"><%= t("schedules.cannot_edit_after_service_started") %></div>
    </div>
  <% end %>

  <div class="row g-4">
    <div class="col-lg-8">
      <div class="card shadow-sm mb-4">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
              <span class="badge <%= @schedule.status_badge_class %> mb-2">
                <%= t("schedules.statuses.#{@schedule.status}") %>
              </span>
              <h2 class="h4 mb-1"><%= @schedule.service_order.title %></h2>
              <p class="text-muted mb-0 font-monospace"><%= @schedule.service_order.code %></p>
            </div>
            <% if can?(:update, @schedule) %>
              <%= link_to edit_schedule_path(@schedule), class: "btn btn-outline-primary" do %>
                <%= icon_svg(:wrench, width: 18, height: 18) %> Editar
              <% end %>
            <% end %>
          </div>
          <dl class="row mb-0">
            <dt class="col-sm-3">Início</dt>
            <dd class="col-sm-9">
              <% if @schedule.scheduled_at.present? %>
                <%= l(@schedule.scheduled_at, format: :long) %>
              <% else %>
                <span class="text-muted"><%= t("schedules.time_to_be_defined") %></span>
              <% end %>
            </dd>
            <% if @schedule.scheduled_end_at.present? %>
              <dt class="col-sm-3">Término</dt>
              <dd class="col-sm-9"><%= l(@schedule.scheduled_end_at, format: :long) %></dd>
            <% end %>
            <dt class="col-sm-3">Secretaria</dt>
            <dd class="col-sm-9"><%= @schedule.secretary.name %></dd>
          </dl>
          <% if @schedule.observations.present? %>
            <hr>
            <h6 class="text-muted small">Observações</h6>
            <%= simple_format(@schedule.observations) %>
          <% end %>
        </div>
      </div>

      <div class="card shadow-sm mb-4">
        <div class="card-header bg-white">
          <h6 class="mb-0">
            <%= icon_svg(:tractor, width: 18, height: 18, class: "me-2") %>
            Maquinário
          </h6>
        </div>
        <% if @schedule.machines.any? %>
          <ul class="list-group list-group-flush">
            <% @schedule.machines.each do |machine| %>
              <li class="list-group-item"><%= machine.name %> <small class="text-muted">(<%= machine.plate %>)</small></li>
            <% end %>
          </ul>
        <% else %>
          <div class="card-body text-muted">Nenhum maquinário alocado.</div>
        <% end %>
      </div>

      <div class="card shadow-sm">
        <div class="card-header bg-white">
          <h6 class="mb-0">
            <%= icon_svg(:users, width: 18, height: 18, class: "me-2") %>
            Equipe
          </h6>
        </div>
        <% if @schedule.assigned_users.any? %>
          <ul class="list-group list-group-flush">
            <% @schedule.assigned_users.each do |user| %>
              <li class="list-group-item"><%= user.name %></li>
            <% end %>
          </ul>
        <% else %>
          <div class="card-body text-muted">Nenhum membro da equipe alocado.</div>
        <% end %>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="card shadow-sm mb-4">
        <div class="card-body">
          <h6 class="text-muted small">Ordem de Serviço</h6>
          <%= link_to @schedule.service_order.code, service_order_path(@schedule.service_order), class: "fw-medium", data: { turbo_frame: "_top" } %>
          <p class="text-muted small mb-0 mt-1"><%= @schedule.service_order.title %></p>
          <div class="mt-2">
            <span class="badge <%= @schedule.service_order.status_badge_class %>">
              <%= t("service_orders.statuses.#{@schedule.service_order.status}") %>
            </span>
          </div>
        </div>
      </div>

      <% order = @schedule.service_order %>
      <% if can?(:update, order) && !@schedule.status_cancelled? && !order.status_cancelled? && !order.status_completed? %>
        <div class="card shadow-sm mb-4">
          <div class="card-header bg-white">
            <h6 class="mb-0"><%= icon_svg(:clipboard, width: 18, height: 18, class: "me-2") %> Execução da OS</h6>
          </div>
          <div class="card-body">
            <p class="small text-muted mb-3"><%= t("schedules.service_order_execution_help") %></p>
            <dl class="row small mb-3">
              <dt class="col-5 text-muted">Início</dt>
              <dd class="col-7 mb-0">
                <% if @schedule.scheduled_at.present? %>
                  <%= l(@schedule.scheduled_at, format: :short) %>
                <% else %>
                  <span class="text-muted"><%= t("schedules.time_to_be_defined") %></span>
                <% end %>
              </dd>
              <dt class="col-5 text-muted">Término</dt>
              <dd class="col-7 mb-0">
                <% if @schedule.scheduled_end_at.present? %>
                  <%= l(@schedule.scheduled_end_at, format: :short) %>
                <% else %>
                  <span class="text-muted"><%= t("schedules.time_to_be_defined") %></span>
                <% end %>
              </dd>
            </dl>
            <div class="d-grid gap-2">
              <% if (order.status_pending? || order.status_scheduled?) && order.payment_receipt_approved? %>
                <%= button_to t("schedules.start_service_order"), start_service_order_schedule_path(@schedule), method: :patch, class: "btn btn-success", data: { turbo_confirm: "Iniciar agora? O início do agendamento e da OS será o horário deste clique." } %>
              <% elsif order.status_pending? || order.status_scheduled? %>
                <p class="small text-warning mb-0"><%= t("service_orders.cannot_start_no_receipt") %></p>
              <% end %>

              <% if order.status_in_progress? %>
                <%= button_to t("schedules.complete_service_order"), complete_service_order_schedule_path(@schedule), method: :patch, class: "btn btn-outline-success", data: { turbo_confirm: "Finalizar agora? O término do agendamento e da OS será o horário deste clique." } %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>

      <div class="d-grid gap-2">
        <%= link_to "Ver calendário", calendar_schedules_path, class: "btn btn-outline-primary" %>
        <%= link_to "Voltar à lista", schedules_path, class: "btn btn-outline-secondary" %>
      </div>
    </div>
  </div>
</div>
