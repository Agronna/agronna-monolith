<div class="container-fluid py-4">
  <div class="mb-4">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb mb-2">
        <li class="breadcrumb-item"><%= link_to "Agendamentos", schedules_path %></li>
        <li class="breadcrumb-item"><%= link_to "Agendamento", schedule_path(@schedule) %></li>
        <li class="breadcrumb-item active" aria-current="page">Editar</li>
      </ol>
    </nav>
    <h1 class="h3 mb-1">Editar Agendamento</h1>
    <p class="text-muted mb-0">
      <%= @schedule.service_order.code %>
      <% if @schedule.scheduled_at.present? %>
        — <%= l(@schedule.scheduled_at, format: :short) %>
      <% else %>
        — <span class="text-muted"><%= t("schedules.time_to_be_defined") %></span>
      <% end %>
    </p>
  </div>

  <%= render "form" %>
</div>
