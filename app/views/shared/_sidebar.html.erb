<aside class="admin-sidebar" id="adminSidebar" aria-label="Menu principal">
  <div class="sidebar-brand">
    <span class="sidebar-brand__logo" aria-hidden="true">AG</span>
    <span class="sidebar-brand__name">Agronna</span>
  </div>

  <nav class="sidebar-nav">
    <p class="sidebar-nav__group">Principal</p>
    <ul class="sidebar-nav__list">
      <li>
        <%= link_to root_path, class: "sidebar-nav__link #{'sidebar-nav__link--active' if controller_name == 'home' || current_page?(root_path)}" do %>
          <%= icon_svg(:dashboard, class: "sidebar-icon") %>
          <span>Dashboard</span>
        <% end %>
      </li>
    </ul>

    <p class="sidebar-nav__group">Gestão</p>
    <ul class="sidebar-nav__list">
      <li>
        <%= link_to "#", class: "sidebar-nav__link #{'sidebar-nav__link--active' if false}" do %>
          <%= icon_svg(:calendar, class: "sidebar-icon") %>
          <span>Agendamento</span>
        <% end %>
      </li>
      <li>
        <%= link_to "#", class: "sidebar-nav__link" do %>
          <%= icon_svg(:chart, class: "sidebar-icon") %>
          <span>Ativos e Passivos</span>
        <% end %>
      </li>
      <li>
        <%= link_to "#", class: "sidebar-nav__link" do %>
          <%= icon_svg(:receipt, class: "sidebar-icon") %>
          <span>Comprovantes de Pagamento</span>
        <% end %>
      </li>
      <li>
        <%= link_to "#", class: "sidebar-nav__link" do %>
          <%= icon_svg(:clipboard, class: "sidebar-icon") %>
          <span>Ordem de Serviço</span>
        <% end %>
      </li>
      <li>
        <%= link_to machines_path, class: "sidebar-nav__link #{'sidebar-nav__link--active' if controller_name == 'machines'}" do %>
          <%= icon_svg(:tractor, class: "sidebar-icon") %>
          <span>Maquinários</span>
        <% end %>
      </li>
      <li>
        <%= link_to "#", class: "sidebar-nav__link" do %>
          <%= icon_svg(:wrench, class: "sidebar-icon") %>
          <span>Prestadores de Serviços</span>
        <% end %>
      </li>
      <li>
        <%= link_to producers_path, class: "sidebar-nav__link #{'sidebar-nav__link--active' if controller_name == 'producers'}" do %>
          <%= icon_svg(:user, class: "sidebar-icon") %>
          <span>Produtores</span>
        <% end %>
      </li>
      <li>
        <%= link_to "#", class: "sidebar-nav__link" do %>
          <%= icon_svg(:land, class: "sidebar-icon") %>
          <span>Propriedades</span>
        <% end %>
      </li>
    </ul>

    <p class="sidebar-nav__group">Conta</p>
    <ul class="sidebar-nav__list">
      <li>
        <%= link_to secretaries_path, class: "sidebar-nav__link #{'sidebar-nav__link--active' if controller_name == 'secretaries'}" do %>
          <%= icon_svg(:office, class: "sidebar-icon") %>
          <span>Secretarias</span>
        <% end %>
      </li>
      <li>
        <%= link_to users_path, class: "sidebar-nav__link #{'sidebar-nav__link--active' if controller_name == 'users'}" do %>
          <%= icon_svg(:users, class: "sidebar-icon") %>
          <span>Usuários</span>
        <% end %>
      </li>
      <li>
        <%= link_to "#", class: "sidebar-nav__link" do %>
          <%= icon_svg(:users, class: "sidebar-icon") %>
          <span>Funcionários da Secretária</span>
        <% end %>
      </li>
    </ul>
  </nav>

  <button type="button" class="sidebar-close d-lg-none" id="sidebarClose" aria-label="Fechar menu">
    <%= icon_svg(:close, width: 24, height: 24) %>
  </button>
</aside>
<div class="sidebar-overlay" id="sidebarOverlay" aria-hidden="true"></div>
