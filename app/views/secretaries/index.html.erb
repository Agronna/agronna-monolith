<div class="container mt-4">

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Secretarias</h2>

    <% if can? :create, Secretary %>
      <%= link_to "Nova Secretária", new_secretary_path, class: "btn btn-primary" %>
    <% end %>
  </div>

  <%= search_form_for @q, url: secretaries_path, method: :get, html: { class: "mb-4", data: { turbo_frame: "secretaries_list" } } do |f| %>
    <div class="card shadow-sm mb-3">
      <div class="card-body">
        <h6 class="card-title mb-3">Filtrar</h6>
        <div class="row g-2 g-md-3 align-items-end">
          <div class="col-12 col-sm-6 col-lg-3">
            <%= f.label :name_cont, "Nome", class: "form-label small text-muted" %>
            <%= f.search_field :name_cont, class: "form-control form-control-sm", placeholder: "Contém..." %>
          </div>
          <div class="col-12 col-sm-6 col-lg-3">
            <%= f.label :cnpj_cont, "CNPJ", class: "form-label small text-muted" %>
            <%= f.search_field :cnpj_cont, class: "form-control form-control-sm", placeholder: "Contém..." %>
          </div>
          <div class="col-12 col-sm-6 col-lg-2">
            <%= f.label :email_cont, "E-mail", class: "form-label small text-muted" %>
            <%= f.search_field :email_cont, class: "form-control form-control-sm", placeholder: "Contém..." %>
          </div>
          <div class="col-12 col-sm-6 col-lg-2">
            <%= f.label :prefecture_name_cont, "Prefeitura", class: "form-label small text-muted" %>
            <%= f.search_field :prefecture_name_cont, class: "form-control form-control-sm", placeholder: "Contém..." %>
          </div>

          <div class="col-12 col-lg-2 d-flex align-items-end gap-1">
            <%= f.submit "Filtrar", class: "btn btn-primary btn-sm me-1" %>
            <%= link_to "Limpar", secretaries_path, class: "btn btn-outline-secondary btn-sm", data: { turbo_frame: "secretaries_list" } %>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <%= turbo_frame_tag "secretaries_list" do %>
    <div class="card shadow-sm">
      <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-2">
          <p class="text-muted small mb-0">
            <% if @pagy.present? %>
              <%== @pagy.info_tag(item_name: "secretaria") %>
            <% else %>
              <%= @secretaries.size %> secretaria(s)
            <% end %>
          </p>
        </div>

        <div class="table-responsive">
          <table class="table table-striped table-hover align-middle">

            <thead class="table-light">
              <tr>
                <th>CNPJ</th>
                <th>Nome</th>
                <th>Razão Social</th>
                <th>Prefeitura</th>
                <th>E-mail</th>
                <th>Status</th>
                <th class="text-end">Ações</th>
              </tr>
            </thead>

            <tbody>
              <% @secretaries.each do |secretary| %>
                <tr>
                  <td><%= secretary.cnpj %></td>
                  <td><strong><%= secretary.name %></strong></td>
                  <td><%= secretary.corporate_name %></td>
                  <td><%= secretary.prefecture_name %></td>
                  <td><%= secretary.email %></td>
                  <td>
                    <span class="badge <%= secretary.status_active? ? 'bg-success' : 'bg-secondary' %>">
                      <%= secretary.status_active? ? "Ativo" : "Inativo" %>
                    </span>
                  </td>
                  <td class="text-end">
                    <% if can? :update, secretary %>
                      <%= link_to "Editar", edit_secretary_path(secretary), class: "btn btn-sm btn-outline-primary", data: { turbo_frame: "_top" } %>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>

          </table>
        </div>

        <div class="d-flex justify-content-center mt-3">
          <% if @pagy.present? && @pagy.pages > 1 %>
            <nav aria-label="Navegação de páginas" class="pagy-bootstrap-nav">
              <%== @pagy.series_nav("bootstrap") %>
            </nav>
          <% end %>
        </div>

      </div>
    </div>
  <% end %>

</div>