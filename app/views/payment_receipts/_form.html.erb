<%= form_with model: @payment_receipt, local: true, url: @payment_receipt.persisted? ? payment_receipt_path(@payment_receipt) : payment_receipts_path, method: @payment_receipt.persisted? ? :patch : :post, html: { class: "needs-validation", multipart: true } do |f| %>
  <% if @payment_receipt.errors.any? %>
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
      <strong>Atenção!</strong> <%= pluralize(@payment_receipt.errors.count, "erro encontrado", "erros encontrados") %>:
      <ul class="mb-0 mt-2">
        <% @payment_receipt.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
    </div>
  <% end %>

  <%= f.hidden_field :return_to, value: params[:return_to] %>

  <div class="row g-4">
    <div class="col-lg-8">
      <div class="card shadow-sm mb-4">
        <div class="card-header bg-white">
          <h6 class="mb-0">
            <%= icon_svg(:receipt, width: 18, height: 18, class: "me-2") %>
            Dados do Pagamento
          </h6>
        </div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-md-6">
              <%= f.label :service_order_id, t("activerecord.attributes.payment_receipt.service_order"), class: "form-label" %>
              <%= f.collection_select :service_order_id, @service_orders, :id, :code, { prompt: "Selecione a Ordem de Serviço..." }, { class: "form-select", required: true } %>
              <small class="text-muted">OS à qual este comprovante se refere</small>
            </div>
            <div class="col-md-6">
              <%= f.label :payment_date, t("activerecord.attributes.payment_receipt.payment_date"), class: "form-label" %>
              <%= f.date_field :payment_date, class: "form-control", required: true %>
            </div>
            <div class="col-md-6">
              <%= f.label :amount, t("activerecord.attributes.payment_receipt.amount"), class: "form-label" %>
              <%= f.number_field :amount, class: "form-control", step: 0.01, min: 0.01, placeholder: "0,00", required: true %>
            </div>
            <div class="col-md-6">
              <%= f.label :reference, t("activerecord.attributes.payment_receipt.reference"), class: "form-label" %>
              <%= f.text_field :reference, class: "form-control", placeholder: "Ex: Nº do documento bancário" %>
            </div>
            <div class="col-12">
              <%= f.label :description, t("activerecord.attributes.payment_receipt.description"), class: "form-label" %>
              <%= f.text_area :description, class: "form-control", rows: 2, placeholder: "Descrição do pagamento (opcional)" %>
            </div>
            <div class="col-12">
              <%= f.label :secretary_id, t("activerecord.attributes.payment_receipt.secretary"), class: "form-label" %>
              <%= f.collection_select :secretary_id, @secretaries, :id, :name, { prompt: "Selecione..." }, { class: "form-select", required: true } %>
            </div>
            <div class="col-12">
              <%= f.label :producer_id, t("activerecord.attributes.payment_receipt.producer"), class: "form-label" %>
              <%= f.collection_select :producer_id, @producers, :id, :name, { include_blank: "Nenhum produtor" }, { class: "form-select" } %>
            </div>
          </div>
        </div>
      </div>

      <div class="card shadow-sm mb-4">
        <div class="card-header bg-white">
          <h6 class="mb-0">
            <%= icon_svg(:receipt, width: 18, height: 18, class: "me-2") %>
            Anexar Comprovante
          </h6>
        </div>
        <div class="card-body">
          <p class="text-muted small mb-3">
            Envie uma imagem (JPEG, PNG, GIF, WebP) ou PDF do comprovante de pagamento. Tamanho máximo: 10 MB.
          </p>
          <%= f.file_field :file, accept: "image/*,.pdf", class: "form-control", direct_upload: true %>
          <% if @payment_receipt.file.attached? %>
            <div class="mt-3">
              <p class="small mb-1">Arquivo atual:</p>
              <span class="badge bg-light text-dark"><%= @payment_receipt.file.filename %></span>
              <small class="text-muted d-block mt-1">Envie outro arquivo para substituir.</small>
            </div>
          <% end %>
        </div>
      </div>

      <div class="card shadow-sm">
        <div class="card-body">
          <%= f.label :observations, t("activerecord.attributes.payment_receipt.observations"), class: "form-label" %>
          <%= f.text_area :observations, class: "form-control", rows: 3, placeholder: "Observações internas (opcional)" %>
        </div>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="card shadow-sm mb-4">
        <div class="card-body">
          <p class="small text-muted mb-3">
            O pagamento é realizado fora do sistema. O produtor entrega o comprovante para anexar aqui; após aprovação, a Ordem de Serviço poderá ser iniciada.
          </p>
        </div>
      </div>
      <div class="d-grid gap-2">
        <%= f.submit @payment_receipt.persisted? ? "Atualizar Comprovante" : "Cadastrar Comprovante", class: "btn btn-primary btn-lg" %>
        <%= link_to "Cancelar", @payment_receipt.service_order.present? ? service_order_path(@payment_receipt.service_order) : payment_receipts_path, class: "btn btn-outline-secondary" %>
      </div>
    </div>
  </div>
<% end %>
