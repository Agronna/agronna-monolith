<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6">

      <div class="card shadow-sm">
        <div class="card-body">

          <h3 class="card-title mb-4 text-center">
            Teste Bootstrap + Rails 8
          </h3>

          <% if flash[:notice] %>
            <div class="alert alert-success" role="alert">
              <%= flash[:notice] %>
            </div>
          <% end %>

          <%= form_with url: home_submit_path, method: :post, local: true do %>

            <div class="mb-3">
              <%= label_tag :nome, "Nome", class: "form-label" %>
              <%= text_field_tag :nome, @nome, class: "form-control", placeholder: "Digite seu nome" %>
            </div>

            <div class="mb-3">
              <%= label_tag :email, "E-mail", class: "form-label" %>
              <%= email_field_tag :email, @email, class: "form-control", placeholder: "email@exemplo.com" %>
            </div>

            <div class="d-grid">
              <%= submit_tag "Enviar", class: "btn btn-primary" %>
            </div>

          <% end %>

        </div>
      </div>

    </div>
  </div>
</div>
