<div class="container mt-4">

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Produtores</h2>

    <% if can? :create, Producer %>
      <%= link_to "Novo Produtor", new_producer_path, class: "btn btn-primary" %>
    <% end %>
  </div>

  <%= search_form_for @q, url: producers_path, method: :get, html: { class: "mb-4", data: { turbo_frame: "producers_list" } } do |f| %>
    <div class="card shadow-sm mb-3">
      <div class="card-body">
        <h6 class="card-title mb-3">Filtrar</h6>
        <div class="row g-2 g-md-3 align-items-end">
          <div class="col-12 col-sm-6 col-lg-4">
            <%= f.label :name_cont, "Nome", class: "form-label small text-muted" %>
            <%= f.search_field :name_cont, class: "form-control form-control-sm", placeholder: "Contém..." %>
          </div>
          <div class="col-12 col-sm-6 col-lg-3">
            <%= f.label :cpf_cont, "CPF", class: "form-label small text-muted" %>
            <%= f.search_field :cpf_cont, class: "form-control form-control-sm", placeholder: "Contém..." %>
          </div>
          <div class="col-12 col-sm-6 col-lg-3">
            <%= f.label :email_cont, "E-mail", class: "form-label small text-muted" %>
            <%= f.search_field :email_cont, class: "form-control form-control-sm", placeholder: "Contém..." %>
          </div>
          <div class="col-12 col-lg-1 d-flex align-items-end gap-1">
            <%= f.submit "Filtrar", class: "btn btn-primary btn-sm" %>
            <%= link_to "Limpar", producers_path, class: "btn btn-outline-secondary btn-sm", data: { turbo_frame: "producers_list" } %>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <%= turbo_frame_tag "producers_list" do %>
    <div class="card shadow-sm">
      <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-2">
          <p class="text-muted small mb-0">
            <% if @pagy.present? %>
              <%== @pagy.info_tag(item_name: "produtor") %>
            <% else %>
              <%= @producers.size %> produtor(es)
            <% end %>
          </p>
        </div>

        <div class="table-responsive">
          <table class="table table-striped table-hover align-middle">

            <thead class="table-light">
              <tr>
                <th>Nome</th>
                <th>CPF</th>
                <th>E-mail</th>
                <th>Telefone</th>
                <th>Data de Nascimento</th>
                <th>Status</th>
                <th class="text-end">Ações</th>
              </tr>
            </thead>

            <tbody>
              <% @producers.each do |producer| %>
                <tr>
                  <td><strong><%= producer.name %></strong></td>
                  <td><%= producer.cpf %></td>
                  <td><%= producer.email.presence || "—" %></td>
                  <td><%= producer.phone.presence || "—" %></td>
                  <td><%= producer.birth_date.present? ? l(producer.birth_date, format: :default) : "—" %></td>
                  <td>
                    <span class="badge <%= producer.status_active? ? 'bg-success' : 'bg-secondary' %>">
                      <%= producer.status_active? ? "Ativo" : "Inativo" %>
                    </span>
                  </td>
                  <td class="text-end">
                    <% if can? :update, producer %>
                      <%= link_to "Editar", edit_producer_path(producer), class: "btn btn-sm btn-outline-primary", data: { turbo_frame: "_top" } %>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>

          </table>
        </div>

        <div class="d-flex justify-content-center mt-3">
          <% if @pagy.present? && @pagy.pages > 1 %>
            <nav aria-label="Navegação de páginas" class="pagy-bootstrap-nav">
              <%== @pagy.series_nav("bootstrap") %>
            </nav>
          <% end %>
        </div>

      </div>
    </div>
  <% end %>

</div>
