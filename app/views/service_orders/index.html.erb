<div class="container-fluid py-4">
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4">
    <div>
      <h1 class="h3 mb-1">Ordens de Serviço</h1>
      <p class="text-muted mb-0">Gerencie as ordens de serviço do sistema</p>
    </div>
    <% if can?(:create, ServiceOrder) %>
      <%= link_to new_service_order_path, class: "btn btn-primary mt-3 mt-md-0" do %>
        <%= icon_svg(:clipboard, width: 20, height: 20, class: "me-1") %>
        Nova Ordem de Serviço
      <% end %>
    <% end %>
  </div>

  <%= search_form_for @q, url: service_orders_path, method: :get, html: { class: "mb-4", data: { turbo_frame: "service_orders_list" } } do |f| %>
    <div class="card shadow-sm mb-3">
      <div class="card-body">
        <h6 class="card-title mb-3">Filtrar</h6>
        <div class="row g-2 g-md-3 align-items-end">
          <div class="col-12 col-sm-6 col-lg-2">
            <%= f.label :code_cont, "Código", class: "form-label small text-muted" %>
            <%= f.search_field :code_cont, class: "form-control form-control-sm", placeholder: "OS-2026-..." %>
          </div>
          <div class="col-12 col-sm-6 col-lg-2">
            <%= f.label :title_cont, "Título", class: "form-label small text-muted" %>
            <%= f.search_field :title_cont, class: "form-control form-control-sm", placeholder: "Contém..." %>
          </div>
          <div class="col-12 col-sm-6 col-lg-2">
            <%= f.label :status_eq, "Status", class: "form-label small text-muted" %>
            <%= f.select :status_eq, ServiceOrder.statuses.map { |k, v| [t("service_orders.statuses.#{k}"), v] }, { include_blank: "Todos" }, class: "form-select form-select-sm" %>
          </div>
          <div class="col-12 col-sm-6 col-lg-2">
            <%= f.label :priority_eq, "Prioridade", class: "form-label small text-muted" %>
            <%= f.select :priority_eq, ServiceOrder.priorities.map { |k, v| [t("service_orders.priorities.#{k}"), v] }, { include_blank: "Todas" }, class: "form-select form-select-sm" %>
          </div>
          <div class="col-12 col-sm-6 col-lg-2">
            <%= f.label :deadline_lteq, "Prazo até", class: "form-label small text-muted" %>
            <%= f.date_field :deadline_lteq, class: "form-control form-control-sm" %>
          </div>
          <div class="col-12 col-lg-2 d-flex align-items-end gap-1">
            <%= f.submit "Filtrar", class: "btn btn-primary btn-sm me-1" %>
            <%= link_to "Limpar", service_orders_path, class: "btn btn-outline-secondary btn-sm", data: { turbo_frame: "service_orders_list" } %>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <%= turbo_frame_tag "service_orders_list" do %>
    <div class="card shadow-sm">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th class="ps-3">Código</th>
                <th>Título</th>
                <th>Secretaria</th>
                <th class="text-center">Prazo</th>
                <th class="text-center">Prioridade</th>
                <th class="text-center">Status</th>
                <th>Responsável</th>
                <th class="text-center">Equipamentos</th>
                <th class="text-end pe-3">Ações</th>
              </tr>
            </thead>
            <tbody>
              <% if @service_orders.any? %>
                <% @service_orders.each do |order| %>
                  <tr class="<%= 'table-danger' if order.overdue? %>">
                    <td class="ps-3">
                      <span class="fw-medium font-monospace"><%= order.code %></span>
                    </td>
                    <td>
                      <div class="text-truncate" style="max-width: 200px;" title="<%= order.title %>">
                        <%= order.title %>
                      </div>
                      <% if order.property.present? %>
                        <small class="text-muted d-block">
                          <%= icon_svg(:land, width: 12, height: 12) %>
                          <%= order.property.name %>
                        </small>
                      <% end %>
                    </td>
                    <td>
                      <small><%= order.secretary.name %></small>
                    </td>
                    <td class="text-center">
                      <span class="<%= order.overdue? ? 'text-danger fw-bold' : '' %>">
                        <%= l(order.deadline, format: :short) %>
                      </span>
                      <% if order.overdue? %>
                        <br><small class="text-danger">Atrasada</small>
                      <% end %>
                    </td>
                    <td class="text-center">
                      <span class="badge <%= order.priority_badge_class %>">
                        <%= t("service_orders.priorities.#{order.priority}") %>
                      </span>
                    </td>
                    <td class="text-center">
                      <span class="badge <%= order.status_badge_class %>">
                        <%= t("service_orders.statuses.#{order.status}") %>
                      </span>
                    </td>
                    <td>
                      <% if order.assigned_to.present? %>
                        <small><%= order.assigned_to.name %></small>
                      <% else %>
                        <small class="text-muted">Não atribuído</small>
                      <% end %>
                    </td>
                    <td class="text-center">
                      <% if order.machines.any? %>
                        <span class="badge bg-secondary" title="<%= order.machines.pluck(:name).join(', ') %>">
                          <%= icon_svg(:tractor, width: 14, height: 14) %>
                          <%= order.machines.count %>
                        </span>
                      <% else %>
                        <span class="text-muted">-</span>
                      <% end %>
                    </td>
                    <td class="text-end pe-3">
                      <div class="btn-group btn-group-sm">
                        <%= link_to service_order_path(order), class: "btn btn-outline-secondary", title: "Visualizar", data: { turbo_frame: "_top" } do %>
                          <%= icon_svg(:clipboard, width: 16, height: 16) %>
                        <% end %>

                        <% if can?(:update, order) %>
                          <%= link_to edit_service_order_path(order), class: "btn btn-outline-primary", title: "Editar", data: { turbo_frame: "_top" } do %>
                            <%= icon_svg(:wrench, width: 16, height: 16) %>
                          <% end %>
                        <% end %>

                        <% if order.status_pending? || order.status_scheduled? %>
                          <% if can?(:update, order) %>
                            <%= button_to start_service_order_path(order), method: :patch, class: "btn btn-outline-success", title: "Iniciar", data: { turbo_confirm: "Deseja iniciar esta ordem de serviço?" } do %>
                              <%= icon_svg(:arrow_right, width: 16, height: 16) %>
                            <% end %>
                          <% end %>
                        <% elsif order.status_in_progress? %>
                          <% if can?(:update, order) %>
                            <%= button_to complete_service_order_path(order), method: :patch, class: "btn btn-outline-success", title: "Finalizar", data: { turbo_confirm: "Deseja finalizar esta ordem de serviço?" } do %>
                              ✓
                            <% end %>
                          <% end %>
                        <% end %>

                        <% if can?(:update, order) && !order.status_completed? && !order.status_cancelled? %>
                          <%= button_to cancel_service_order_path(order), method: :patch, class: "btn btn-outline-danger", title: "Cancelar", data: { turbo_confirm: "Deseja cancelar esta ordem de serviço?" } do %>
                            <%= icon_svg(:close, width: 16, height: 16) %>
                          <% end %>
                        <% end %>
                      </div>
                    </td>
                  </tr>
                <% end %>
              <% else %>
                <tr>
                  <td colspan="9" class="text-center py-5 text-muted">
                    <%= icon_svg(:clipboard, width: 48, height: 48, class: "mb-3 opacity-50") %>
                    <p class="mb-0">Nenhuma ordem de serviço encontrada.</p>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>

      <% if @service_orders.any? %>
        <div class="d-flex justify-content-center mt-3">
          <nav aria-label="Paginação">
            <%== @pagy.series_nav("bootstrap") %>
          </nav>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
