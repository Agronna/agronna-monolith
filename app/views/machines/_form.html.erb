<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">

      <div class="card shadow-sm">
        <div class="card-body">

          <h3 class="card-title mb-4 text-center">
            <%= @machine.new_record? ? "Novo Maquinário" : "Editar Maquinário" %>
          </h3>

          <% if @machine.errors.any? %>
            <div class="alert alert-danger">
              <strong><%= pluralize(@machine.errors.count, "erro") %> impediram de salvar:</strong>
              <ul class="mb-0">
                <% @machine.errors.full_messages.each do |msg| %>
                  <li><%= msg %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <%= form_with model: @machine, local: true do |f| %>

            <h6 class="text-muted border-bottom pb-2 mb-3">Dados do maquinário</h6>

            <div class="row g-3">
              <div class="col-md-6">
                <%= f.label :name, "Nome", class: "form-label" %>
                <%= f.text_field :name, class: "form-control", placeholder: "Nome do maquinário", required: true %>
              </div>
              <div class="col-md-6">
                <%= f.label :chassis, "Chassi", class: "form-label" %>
                <%= f.text_field :chassis, class: "form-control", placeholder: "Número do chassi", required: true %>
              </div>
              <div class="col-md-6">
                <%= f.label :plate, "Placa", class: "form-label" %>
                <%= f.text_field :plate, class: "form-control", placeholder: "ABC1D23", required: true %>
              </div>
              <div class="col-md-3">
                <%= f.label :manufacturing_year, "Ano de Fabricação", class: "form-label" %>
                <%= f.number_field :manufacturing_year, class: "form-control", placeholder: "Ex: 2024", required: true, min: 1900, max: Date.current.year + 1 %>
              </div>
              <div class="col-md-3">
                <%= f.label :status, "Status", class: "form-label" %>
                <%= f.select :status,
                  Machine.statuses.keys.map { |s| [s == "active" ? "Ativo" : "Inativo", s] },
                  {},
                  class: "form-select", required: true %>
              </div>
              <div class="col-md-6">
                <%= f.label :function, "Função", class: "form-label" %>
                <%= f.text_field :function, class: "form-control", placeholder: "Ex: Trator, Colheitadeira", required: true %>
              </div>
              <div class="col-md-6">
                <%= f.label :secretary_id, "Secretaria", class: "form-label" %>
                <%= f.collection_select :secretary_id, @secretaries, :id, :name,
                  { prompt: "Selecione a secretaria" },
                  class: "form-select", required: true %>
              </div>
            </div>

            <div class="d-grid mt-4">
              <%= f.submit (@machine.new_record? ? "Criar Maquinário" : "Salvar Alterações"), class: "btn btn-primary" %>
            </div>

          <% end %>

        </div>
      </div>

    </div>
  </div>
</div>
