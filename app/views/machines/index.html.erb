<div class="container mt-4">

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Maquinários</h2>

    <% if can? :create, Machine %>
      <%= link_to "Novo Maquinário", new_machine_path, class: "btn btn-primary" %>
    <% end %>
  </div>

  <%= search_form_for @q, url: machines_path, method: :get, html: { class: "mb-4", data: { turbo_frame: "machines_list" } } do |f| %>
    <div class="card shadow-sm mb-3">
      <div class="card-body">
        <h6 class="card-title mb-3">Filtrar</h6>
        <div class="row g-2 g-md-3 align-items-end">
          <div class="col-12 col-sm-6 col-lg-2">
            <%= f.label :name_cont, "Nome", class: "form-label small text-muted" %>
            <%= f.search_field :name_cont, class: "form-control form-control-sm", placeholder: "Contém..." %>
          </div>
          <div class="col-12 col-sm-6 col-lg-2">
            <%= f.label :chassis_cont, "Chassi", class: "form-label small text-muted" %>
            <%= f.search_field :chassis_cont, class: "form-control form-control-sm", placeholder: "Contém..." %>
          </div>
          <div class="col-12 col-sm-6 col-lg-2">
            <%= f.label :plate_cont, "Placa", class: "form-label small text-muted" %>
            <%= f.search_field :plate_cont, class: "form-control form-control-sm", placeholder: "Contém..." %>
          </div>
          <div class="col-12 col-sm-6 col-lg-2">
            <%= f.label :function_cont, "Função", class: "form-label small text-muted" %>
            <%= f.search_field :function_cont, class: "form-control form-control-sm", placeholder: "Contém..." %>
          </div>
          <div class="col-12 col-sm-6 col-lg-2">
            <%= f.label :manufacturing_year_eq, "Ano", class: "form-label small text-muted" %>
            <%= f.number_field :manufacturing_year_eq, class: "form-control form-control-sm", placeholder: "Ex: 2024" %>
          </div>
          <div class="col-12 col-lg-2 d-flex align-items-end gap-1">
            <%= f.submit "Filtrar", class: "btn btn-primary btn-sm" %>
            <%= link_to "Limpar", machines_path, class: "btn btn-outline-secondary btn-sm", data: { turbo_frame: "machines_list" } %>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <%= turbo_frame_tag "machines_list" do %>
    <div class="card shadow-sm">
      <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-2">
          <p class="text-muted small mb-0">
            <% if @pagy.present? %>
              <%== @pagy.info_tag(item_name: "maquinário") %>
            <% else %>
              <%= @machines.size %> maquinário(s)
            <% end %>
          </p>
        </div>

        <div class="table-responsive">
          <table class="table table-striped table-hover align-middle">

            <thead class="table-light">
              <tr>
                <th>Nome</th>
                <th>Chassi</th>
                <th>Placa</th>
                <th>Ano</th>
                <th>Função</th>
                <th>Secretaria</th>
                <th>Status</th>
                <th class="text-end">Ações</th>
              </tr>
            </thead>

            <tbody>
              <% @machines.each do |machine| %>
                <tr>
                  <td><strong><%= machine.name %></strong></td>
                  <td><%= machine.chassis %></td>
                  <td><%= machine.plate %></td>
                  <td><%= machine.manufacturing_year %></td>
                  <td><%= machine.function %></td>
                  <td><%= machine.secretary&.name || "—" %></td>
                  <td>
                    <span class="badge <%= machine.status_active? ? 'bg-success' : 'bg-secondary' %>">
                      <%= machine.status_active? ? "Ativo" : "Inativo" %>
                    </span>
                  </td>
                  <td class="text-end">
                    <% if can? :update, machine %>
                      <%= link_to "Editar", edit_machine_path(machine), class: "btn btn-sm btn-outline-primary", data: { turbo_frame: "_top" } %>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>

          </table>
        </div>

        <div class="d-flex justify-content-center mt-3">
          <% if @pagy.present? && @pagy.pages > 1 %>
            <nav aria-label="Navegação de páginas" class="pagy-bootstrap-nav">
              <%== @pagy.series_nav("bootstrap") %>
            </nav>
          <% end %>
        </div>

      </div>
    </div>
  <% end %>

</div>
